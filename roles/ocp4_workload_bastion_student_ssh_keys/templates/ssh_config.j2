# SSH config for {{ ocp4_workload_bastion_student_ssh_keys_user }}
# Generated by ocp4_workload_bastion_student_ssh_keys role

Host *
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  IdentityFile ~/.ssh/{{ ocp4_workload_bastion_student_ssh_keys_private_key | basename }}

{% for host in ocp4_workload_bastion_student_ssh_keys_target_hosts %}
Host {{ hostvars[host].shortname | default(host) }}
  Hostname {{ hostvars[host].ansible_host | default(hostvars[host].private_ip_address | default(host)) }}
  User {{ ocp4_workload_bastion_student_ssh_keys_remote_user }}

{% endfor %}
